# Supabase — get these from your Supabase project settings (API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key   # server-side only, never expose to client

# Security — salt for one-way IP hashing (rate limiting + vote dedup).
# Generate with: openssl rand -hex 32
IP_HASH_SALT=your_random_64_char_hex_string

# Cron — secret to validate the weekly cron job (set in Vercel later).
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret

# Photos are stored in Supabase Storage (bucket: report-photos) using the keys
# above — no separate storage service or credentials needed (DECISIONS.md D-005).
